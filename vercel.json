{
  "images": {
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/omnifiles/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/portfolio/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/slides/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/fractais/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/r2/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/outros/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/editoriais/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/Art/**",
        "dangerouslyAllowSVG": true
      },
      {
        "protocol": "https",
        "hostname": "**",
        "pathname": "/Diagramas/**",
        "dangerouslyAllowSVG": true
      }
    ]
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, X-UserSession"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *;"
        }
      ]
    }
  ]
}
